{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Decision Engine Baseline\n",
    "\n",
    "This notebook runs a simple end-to-end workflow:\n",
    "\n",
    "- Generate simulated decision data\n",
    "- Perform lightweight EDA\n",
    "- Build features\n",
    "- Train and evaluate a baseline classifier"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "import sys\n",
    "\n",
    "import json\n",
    "import pandas as pd\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "project_root = Path.cwd().parent\n",
    "if str(project_root / 'src') not in sys.path:\n",
    "    sys.path.append(str(project_root / 'src'))\n",
    "\n",
    "from data.simulate import save_dataset\n",
    "from features.build_features import build_feature_table\n",
    "from models.train import train_baseline_model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "raw_path = project_root / 'data/raw/simulated_decision_data.csv'\n",
    "features_path = project_root / 'data/processed/features.csv'\n",
    "\n",
    "save_dataset(raw_path, n_users=2000, random_state=42)\n",
    "build_feature_table(raw_path, features_path)\n",
    "\n",
    "df = pd.read_csv(features_path)\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df.shape, df['is_approved'].value_counts(normalize=True).round(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "eda_cols = [\n",
    "    'credit_score',\n",
    "    'transaction_count_30d',\n",
    "    'avg_transaction_amount',\n",
    "    'behavior_risk_index',\n",
    "    'is_approved',\n",
    "]\n",
    "\n",
    "sns.pairplot(df[eda_cols], hue='is_approved', corner=True, plot_kws={'alpha': 0.3, 's': 15})\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "metrics = train_baseline_model(\n",
    "    feature_table_path=features_path,\n",
    "    model_path=project_root / 'models/baseline_logreg.joblib',\n",
    "    metrics_path=project_root / 'models/metrics.json',\n",
    ")\n",
    "metrics['accuracy'], metrics['roc_auc']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(json.dumps(metrics['classification_report'], indent=2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "with open(project_root / 'models/metrics.json') as f:\n",
    "    stored_metrics = json.load(f)\n",
    "stored_metrics.keys()"
   ]
  }
 ],
